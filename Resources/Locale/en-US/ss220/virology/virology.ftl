# ==================== Reagents ====================
reagent-name-ganoderma-extract = ganoderma extract
reagent-desc-ganoderma-extract = A potent extract of the lingzhi mushroom. As it metabolises it purges every virus from the body, no matter the strain.

reagent-name-birfungin = birfungin
reagent-desc-birfungin = A broad-spectrum antiviral. As it metabolises it drives every virus in the blood dormant, no matter the strain.


reagent-name-stable-mutagen = stable mutagen
reagent-desc-stable-mutagen = A stabilized mutagen used to transcribe and copy viral material without degrading it.
reagent-name-vaccine = vaccine
reagent-desc-vaccine = A tailored vaccine. Enough of it in the bloodstream grants immunity to the virus it was cultured against.

