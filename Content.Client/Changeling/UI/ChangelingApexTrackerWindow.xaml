<!-- SS220 changeling Apex tracker -->
<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'changeling-apex-window-title'}"
                      MinSize="350 300"
                      Resizable="True">
    <BoxContainer Orientation="Vertical" VerticalExpand="True">
        <Label Text="{Loc 'changeling-apex-window-prompt'}"
               Margin="5 0 0 0"
               HorizontalExpand="True" />
        <PanelContainer StyleClasses="HighDivider" />

        <LineEdit Name="SearchBar"
                  PlaceHolder="{Loc 'changeling-apex-window-search'}"
                  HorizontalExpand="True" />
        <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
            <BoxContainer Name="TargetList" Orientation="Vertical" />
        </ScrollContainer>
    </BoxContainer>
</controls:FancyWindow>
