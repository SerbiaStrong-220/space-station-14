<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'pirate-loot-window-title'}"
               MinSize="420 220">
    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  Margin="8"
                  SeparationOverride="8">
        <Label Name="Summary" HorizontalExpand="True" />
        <Label Name="ShiftTotal" HorizontalExpand="True" />
        <Control VerticalExpand="True" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="8">
            <Button Name="AppraiseButton"
                    Text="{Loc 'pirate-loot-window-appraise'}"
                    HorizontalExpand="True"
                    MinHeight="36" />
            <Button Name="SellButton"
                    Text="{Loc 'pirate-loot-window-sell'}"
                    HorizontalExpand="True"
                    MinHeight="36" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
