<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'pirate-recruitment-window-title'}"
               MinSize="380 160">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <Label Text="{Loc 'pirate-recruitment-window-text'}" HorizontalExpand="True" />
        <Control VerticalExpand="True" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="8">
            <Button Name="AcceptButton"
                    Text="{Loc 'pirate-recruitment-window-accept'}"
                    HorizontalExpand="True"
                    MinHeight="36" />
            <Button Name="DeclineButton"
                    Text="{Loc 'pirate-recruitment-window-decline'}"
                    HorizontalExpand="True"
                    MinHeight="36" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
